# Raw scraped CSVs (rebuilt by tools/community_scrapers/siamverified_harvest)
external_data/

# Python build artifacts
scripts/__pycache__/
**/__pycache__/

# Locally cached Google photos (385MB+). Production uses Google CDN URLs
# directly. Keep for backup / future Vercel Blob migration.
public/place-photos/

# Raw bulk gov-data dumps (~200MB CSVs from data.go.th + TAT). Rebuilt by
# scripts/fetch_thai_gov_data.py. The matched output (per_place_verifications.json)
# is what we ship.
public/data/_raw/

# Local detached scraper logs (not source code)
logs/
.dev.log

# Owner outreach queue + drafts contain real email addresses (PII).
# Generated locally by scripts/build_outreach.py — never commit.
outreach/queue.json
outreach/queue.csv
outreach/drafts/
outreach/batches/
outreach/sent/

# Discovery CSVs (scripts/discover_gaps.py output) contain raw scraped
# venue data — don't bloat the repo. README and the script itself ship.
outreach/discovered/*.csv
