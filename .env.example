# siamverified.com — affiliate IDs
#
# Sign up at each program, paste your IDs here, then re-run `npm run data`
# (which calls the Python enrich_klook_deeplinks.py with these env vars).
#
# All affiliate URLs are search URLs (not deep product URLs) — when a visitor
# clicks, the affiliate cookie attribution kicks in on their search page.
#
# ─────────────────────────────────────────────────────────────────────────────

# Klook — biggest activities platform in Asia, strongest in Thailand
# Sign up: https://affiliate.klook.com/  (instant approval)
# After approval: dashboard → Account → Affiliate ID
KLOOK_AID=

# Viator (a TripAdvisor company) — global tours/activities
# Sign up: https://www.viator.com/affiliate.jspa  (manual review, ~3 days)
# After approval: Account → API Settings → Partner ID
VIATOR_AID=

# GetYourGuide — strong in Europe + Asia
# Sign up: https://partner.getyourguide.com/  (manual review, ~5 days)
# Partner Hub → Tracking → Partner ID
GYG_AID=

# Agoda — accommodation (wellness retreats, spa hotels, coworking-with-stay)
# Sign up: https://partners.agoda.com/  (instant approval after profile)
# Account → Sub Affiliate ID (CID)
AGODA_AID=

# Trip.com / Booking.com (via Trip.com group)
# Sign up: https://us.trip.com/partners/affiliate/
TRIP_AID=

# Bookimed — medical tourism (wellness, derma, hair, plastic surgery)
# Sign up: https://partners.bookimed.com/  (approval ~1 day)
# Specifically for: wellness, spa (medical-grade)
BOOKIMED_AID=

# ─────────────────────────────────────────────────────────────────────────────
# Optional analytics (paste IDs to activate)

# Google Analytics 4
# NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# Plausible (privacy-friendly alternative)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=siamverified.com

# ─────────────────────────────────────────────────────────────────────────────
# Once IDs are in place, re-generate deeplinks for all 7 masters:
#
#   py C:\dbd-scraper\_run_enrichment_all.py
#
# Then refresh the site data:
#
#   cd C:\Users\yunmin\Desktop\siamverified
#   npm run data
#   npm run build
#
# Existing places.json keeps PLACEHOLDER_* in the affiliate URLs until you
# do this. PLACEHOLDER doesn't break the links — visitors still land on Klook,
# they just don't carry your tracking. So no rush to fill these.
